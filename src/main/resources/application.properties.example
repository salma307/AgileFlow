# =============================================================
# Example file for local setup (NO REAL SECRETS HERE)
# Copy this file to application.properties and fill your values.
# =============================================================

spring.application.name=backend

server.port=8080
spring.datasource.url=jdbc:h2:file:./data/presencedb;AUTO_SERVER=TRUE
spring.datasource.driver-class-name=org.h2.Driver
spring.datasource.username=sa
spring.datasource.password=
spring.jpa.database-platform=org.hibernate.dialect.H2Dialect
spring.h2.console.enabled=true
spring.h2.console.path=/h2-console
spring.h2.console.settings.web-allow-others=true
spring.jpa.hibernate.ddl-auto=update

# JWT configuration
# Use a long random secret (at least 32 chars)
jwt.secret=CHANGE_ME_WITH_A_LONG_RANDOM_SECRET
jwt.access.duration-ms=900000
jwt.refresh.duration-ms=604800000

# Simple MFA OTP configuration
mfa.otp.duration-minutes=5
mfa.otp.max-attempts=5

# SMTP configuration for OTP email sending
spring.mail.host=smtp.gmail.com
spring.mail.port=587
spring.mail.username=CHANGE_ME_EMAIL@gmail.com
spring.mail.password=CHANGE_ME_APP_PASSWORD
spring.mail.properties.mail.smtp.auth=true
spring.mail.properties.mail.smtp.starttls.enable=true
spring.mail.properties.mail.smtp.starttls.required=true
